# Vite build-time config. These values are baked into the static bundle at build time.
VITE_GA_MEASUREMENT_ID=G-97H86MNHP8
VITE_LEAD_API_PATH=/api/leads

# Host port exposed on the Unraid server. Cloudflare Tunnel should point to this origin.
WEB_PORT=8080

# Allowed browser origins for direct API testing. Same-origin Caddy traffic does not need CORS,
# but these are useful when hitting the lead API directly or running local dev with a proxy.
ALLOWED_ORIGINS=https://preview.southjerseyreal.estate,https://southjerseyreal.estate,https://www.southjerseyreal.estate,http://localhost:5173

# Lead delivery. Configure SMTP, webhook, or both before cutover.
# SMTP example: Gmail app password, Mailgun SMTP, SendGrid SMTP, Postmark SMTP, or mailbox provider SMTP.
LEAD_TO_EMAIL=arthurpisko@gmail.com
LEAD_FROM_EMAIL="South Jersey Real Estate <leads@southjerseyreal.estate>"
LEAD_SMTP_HOST=
LEAD_SMTP_PORT=587
LEAD_SMTP_SECURE=false
LEAD_SMTP_USER=
LEAD_SMTP_PASS=

# Webhook example: Zapier, Make, Pipedream, Google Apps Script, Airtable, CRM endpoint, etc.
LEAD_WEBHOOK_URL=
LEAD_WEBHOOK_HEADER_NAME=
LEAD_WEBHOOK_HEADER_VALUE=

# Basic in-memory rate limiting per visitor IP.
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=20

# Optional: run `docker compose --profile tunnel up -d` when using the included cloudflared service.
CLOUDFLARED_TUNNEL_TOKEN=
