# Vite build-time config. These values are baked into the static bundle at build time.
VITE_GA_MEASUREMENT_ID=G-97H86MNHP8
VITE_SUPABASE_URL=https://sinbxruqlaywvbzcvfli.supabase.co
VITE_TURNSTILE_SITE_KEY=0x4AAAAAAD4GwgGgH6mUSw5r

# Legacy Unraid deployment settings. Keep these only while the NAS rollback stack remains available.
WEB_PORT=8080

# Prebuilt images published by GitHub Actions for Unraid pulls.
WEB_IMAGE=ghcr.io/piskooooo/southjerseyreal.estate:latest
LEAD_API_IMAGE=ghcr.io/piskooooo/southjerseyreal.estate-lead-api:latest

# Everything below this line belongs only to the legacy lead API and Tunnel rollback stack.
# Current Pages builds submit forms directly to Supabase and do not read these values.
# Allowed browser origins for direct legacy API testing.
ALLOWED_ORIGINS=https://preview.southjerseyreal.estate,https://southjerseyreal.estate,https://www.southjerseyreal.estate,http://localhost:5173

# Legacy lead delivery. Configure SMTP, webhook, or both only when restoring an old image.
# Cloudflare Email Routing can receive and forward routed aliases like leads@southjerseyreal.estate,
# but SMTP still requires a real outbound provider.
# SMTP example: Gmail app password, Mailgun SMTP, SendGrid SMTP, Postmark SMTP, or mailbox provider SMTP.
LEAD_TO_EMAIL=leads@southjerseyreal.estate
LEAD_FROM_EMAIL="South Jersey Real Estate <leads@southjerseyreal.estate>"
LEAD_SMTP_HOST=
LEAD_SMTP_PORT=587
LEAD_SMTP_SECURE=false
LEAD_SMTP_USER=
LEAD_SMTP_PASS=

# Webhook example: Zapier, Make, Pipedream, Google Apps Script, Airtable, CRM endpoint, etc.
LEAD_WEBHOOK_URL=
LEAD_WEBHOOK_HEADER_NAME=
LEAD_WEBHOOK_HEADER_VALUE=

# Basic in-memory rate limiting per visitor IP.
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=20

# Optional: run `docker compose --profile tunnel up -d` when using the included cloudflared service.
CLOUDFLARED_TUNNEL_TOKEN=
