    "@types/node": "^22.20.1",
    "@vitejs/plugin-react": "^5.0.0",
    "jsdom": "^29.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "typescript": "^5.8.0",
    "vite": "^7.0.0",
    "vitest": "^4.1.10"
